# Firebase Configuration (Client-side)
# Get these values from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id

# Riot Sign-On (RSO) OAuth Configuration
# Optional for local dev, but required to enable Riot login
NEXT_PUBLIC_RSO_CLIENT_ID=your_rso_client_id
# Keep this aligned with backend RSO_REDIRECT_URI
NEXT_PUBLIC_RSO_REDIRECT_URI=http://localhost:3000/api/auth/rso/callback

# Backend API URL
# Point to your Go API server's /api base
API_URL=http://localhost:8080/api

# WebSocket URL for real-time collaboration
# Point to your Go API server's WebSocket endpoint
NEXT_PUBLIC_WS_URL=ws://localhost:8080
