# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=valo-mapper

# Firebase Configuration
# Path to your Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS="path/to/serviceAccountKey.json"

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Riot Sign-On (RSO) OAuth Configuration
RSO_CLIENT_ID=rso-client-id
RSO_CLIENT_SECRET=rso-client-secret
RSO_REDIRECT_URI=http://localhost:3000/api/auth/rso/callback

# Internal API key used by protected server-to-server endpoints
# Generate a high-entropy value and keep it secret
INTERNAL_API_KEY=your_internal_api_key